# Copy to .env and fill in. Never commit .env.
DOMAIN=app.sailready.ai
POSTGRES_PASSWORD=change-me-long-random
# Optional: change the app role's password after first migration:
#   docker compose -f docker-compose.prod.yml exec db psql -U sailready -c "ALTER ROLE sailready_app PASSWORD '<new-password>';"
# then set it here:
APP_DB_PASSWORD=sailready_app

# Google OAuth client (type: Web application) from console.cloud.google.com
#   Authorized JavaScript origin:  https://app.sailready.ai
#   Authorized redirect URI:       https://app.sailready.ai/oauth2/callback
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxxxxx

# Generate with: python3 -c "import os,base64; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
COOKIE_SECRET=xxxxxxxx
