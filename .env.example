# Local development secrets for `docker compose`.
# Copy to `.env` (gitignored) and set real values:  cp .env.example .env
# These three are interpolated into the compose files and the initial migration.
POSTGRES_PASSWORD=changeme         # admin/superuser password for the app Postgres
APP_DB_PASSWORD=changeme           # password for the RLS-constrained app role (sailready_app)
TEMPORAL_DB_PASSWORD=changeme      # password for Temporal's own Postgres
